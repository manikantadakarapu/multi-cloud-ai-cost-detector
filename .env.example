APP_NAME="Multi-Cloud AI Cost Detective"
APP_ENV=local
APP_VERSION=0.1.0
APP_DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://mcaicd:mcaicd@localhost:5432/mcaicd
POSTGRES_USER=mcaicd
POSTGRES_PASSWORD=mcaicd
POSTGRES_DB=mcaicd
POSTGRES_PORT=5432
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_RATE_LIMIT_PER_MINUTE=60
AUTH_MAX_LOGIN_ATTEMPTS=5

# --- Shared cost-query infrastructure ---
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379
CACHE_TTL_SECONDS=300
RATE_LIMIT_PER_MINUTE=60

# --- AWS ---
# AWS credentials are resolved via the default credential chain:
# 1. AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars
# 2. ~/.aws/credentials (profile)
# 3. EC2/ECS/Lambda IAM roles
# Only set AWS_PROFILE if you want to override the default profile.
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_COST_EXPLORER_ENABLED=true

# --- Azure ---
# Azure credentials are resolved via DefaultAzureCredential by default.
# DefaultAzureCredential tries environment variables, managed identity,
# Azure CLI, and other token sources automatically.
# If AZURE_TENANT_ID, AZURE_CLIENT_ID, and AZURE_CLIENT_SECRET are all
# provided, the provider falls back to ClientSecretCredential explicitly.
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=change-me-to-a-secure-client-secret
AZURE_COST_MANAGEMENT_ENABLED=true
AZURE_REQUEST_TIMEOUT=30
