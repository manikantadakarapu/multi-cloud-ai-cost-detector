APP_NAME="Multi-Cloud AI Cost Detective"
APP_ENV=local
APP_VERSION=0.1.0
APP_DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://mcaicd:mcaicd@localhost:5432/mcaicd
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_RATE_LIMIT_PER_MINUTE=60
AUTH_MAX_LOGIN_ATTEMPTS=5
